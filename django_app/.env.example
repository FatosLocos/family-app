DJANGO_SECRET_KEY=change-this-to-a-long-random-value
FIELD_ENCRYPTION_KEY=separate-long-random-value-for-oauth-and-bank-tokens
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=app.example.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.example.com
DJANGO_FORCE_HTTPS=1
DJANGO_HSTS_SECONDS=31536000
# The application role is not a PostgreSQL superuser, so RLS also protects
# against direct database access through the Django connection.
POSTGRES_PASSWORD=change-me-app-role
POSTGRES_SUPERUSER_PASSWORD=change-me-admin-role
# DATABASE_URL is generated by Docker Compose from POSTGRES_PASSWORD.
# Local development only: uncomment and point to a separate local PostgreSQL database.
# DATABASE_URL=postgresql://family_app@127.0.0.1:5432/family_app
CELERY_BROKER_URL=redis://family-app-redis:6379/0
CELERY_RESULT_BACKEND=redis://family-app-redis:6379/1
# Docker Compose gebruikt de interne servicenaam. Lokale ontwikkeling gebruikt standaard localhost:1984.
GO2RTC_API_URL=http://go2rtc:1984

# Existing edge network on the VPS. Keep this separate from the Django default network.
EDGE_NETWORK=family-app-edge

# Optional environment-level fallbacks. Household-specific credentials are stored encrypted in Settings.
OUTLOOK_CALENDAR_CLIENT_ID=
OUTLOOK_CALENDAR_CLIENT_SECRET=
BUNQ_OAUTH_CLIENT_ID=
BUNQ_OAUTH_CLIENT_SECRET=
