DATABASE_URL=postgresql://family_app:family_app_dev_password@localhost:5432/family_app

# Optional fallback when no household Home Assistant config is saved yet.
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# Optional local Hue live-test fallback.
HUE_BRIDGE_URL=
HUE_APP_KEY=

# Optional Google Home / Nest preparation.
GOOGLE_HOME_CLIENT_ID=
GOOGLE_HOME_CLIENT_SECRET=
GOOGLE_HOME_PROJECT_ID=
# Register this path in Google Cloud OAuth for each deployed origin:
# http://localhost:3001/api/google-home/oauth/callback

# Outlook calendar uses one server-side OAuth app configuration. Family members only sign in and grant consent.
# Register this path in Microsoft Entra App Registration:
# http://localhost:3000/api/outlook-calendar/oauth/callback
OUTLOOK_CALENDAR_CLIENT_ID=
OUTLOOK_CALENDAR_CLIENT_SECRET=
OUTLOOK_CALENDAR_TENANT_ID=consumers

# Optional bunq OAuth fallback env vars. You can also store these via Instellingen.
# Register this path in bunq Developer:
# http://localhost:3001/api/bunq/oauth/callback
BUNQ_OAUTH_CLIENT_ID=
BUNQ_OAUTH_CLIENT_SECRET=

# Optional token for daily grocery price sync cron:
# curl -X POST -H "Authorization: Bearer $SHOPPING_PRICE_SYNC_TOKEN" https://app.example.com/api/shopping/prices/sync
SHOPPING_PRICE_SYNC_TOKEN=

# Optional grocery price providers. Default uses free experimental Checkjebon
# for basisprijzen and PrijsProfeet for aanbiedingen. Use "none" to disable.
SHOPPING_PRICE_PROVIDER=checkjebon
PEPESTO_API_KEY=
SHOPPING_SCRAPER_API_KEY=
APIFY_TOKEN=
APIFY_KAUFLAND_ACTOR_ID=e-commerce~kaufland-fast-product-scraper
APIFY_KAUFLAND_TIMEOUT_MS=5000
APIFY_KAUFLAND_MAX_ITEMS_PER_SYNC=1
WEBSCRAPING_AMSTERDAM_API_KEY=
